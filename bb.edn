{:deps  {}
 :paths []
 :tasks {:requires
         ([clojure.string :as str]
          [clojure.pprint :refer [print-table]]
          [babashka.tasks :refer [shell]])

         :init
         (do (def paths ["src" "test"]))

         dev
         {:doc  "Start a local development server"
          :task (apply clojure "-M:repl/dev:dev" *command-line-args*)}

         test:jvm
         {:doc  "Run all tests or specific test suites"
          :task (apply clojure "-M:dev:kaocha"
                       (if (seq *command-line-args*) *command-line-args* [":unit"]))}

         test:jvm-live
         {:doc  "Run all tests or specific test suites"
          :task (let [present-or-nonempty?
                      (fn [env-var]
                        (let [value (System/getenv env-var)]
                          (and (some? value) (or (= env-var "OLLAMA_API_KEY")
                                                 (seq value)))))
                      services                                                {"OLLAMA_API_KEY"    :llx/ollama
                                                                               "OPENAI_API_KEY"    :llx/openai
                                                                               "ANTHROPIC_API_KEY" :llx/anthropic
                                                                               "GEMINI_API_KEY"    :llx/google
                                                                               "MISTRAL_API_KEY"   :llx/mistral}
                      disabled                                                (->> services
                                                                                   (remove (fn [[env-var _]]
                                                                                             (present-or-nonempty? env-var)))
                                                                                   (mapcat (fn [[_ kw]] ["--skip-meta" (str kw)])))
                      suites                                                  (if (seq *command-line-args*) *command-line-args* [":live"])]
                  (apply clojure "-M:dev:kaocha" (concat suites disabled)))}

         test:watch-cljs
         {:doc  "Watch CLJS tests with shadow-cljs"
          :task (apply clojure "-M:dev:shadow-cljs" "watch" "test" *command-line-args*)}

         test:build-cljs
         {:doc  "Compile CLJS tests with shadow-cljs without autorun"
          :task (apply clojure "-M:dev:shadow-cljs" "compile" "test"
                       "--config-merge" "{:autorun false}" *command-line-args*)}

         test:build-cljs-live
         {:doc  "Compile CLJS live tests with shadow-cljs without autorun"
          :task (apply clojure "-M:dev:shadow-cljs" "compile" "test-live"
                       "--config-merge" "{:autorun false}" *command-line-args*)}

         test:cljs
         {:doc     "Compile and run CLJS tests with shadow-cljs"
          :depends [test:build-cljs]
          :task    (shell "node" "target/tests.js")}

         test:cljs-live
         {:doc     "Compile and run CLJS live tests with shadow-cljs"
          :depends [test:build-cljs-live]
          :task    (shell "node" "target/tests-live.js")}

         test
         {:doc     "TODO this description"
          :depends [test:jvm test:cljs]}

         generate-models
         {:doc  "Generate built-in model catalog artifact"
          :task (do (clojure "-M:dev" "-m" "llx.ai.impl.model-catalog.generate")
                    (shell "cljfmt --quiet fix src/llx/ai/impl/models_generated.cljc"))}

         fmt
         {:doc  "Format code with cljfmt"
          :task (apply shell "cljfmt --quiet -v fix" (if (seq *command-line-args*) *command-line-args* paths))}

         fmt:check
         {:doc  "Check code formatting without making changes"
          :task (apply shell "cljfmt check " paths)}

         prep
         {:doc  "Prepare Clojure dependencies"
          :task (apply clojure "-X:deps prep :aliases '[:dev :kaocha]'")}

         deps-tree
         {:doc  "Show dependency tree"
          :task (clojure "-X:deps tree :aliases '[:dev]'")}

         lint:copy-configs
         {:doc  "Copy clj-kondo configs from dependencies"
          :task (shell "clj-kondo" "--lint" (-> (shell {:out :string} "clojure -Spath -M:test:dev") :out str/trim) "--dependencies" "--copy-configs" "--skip-lint")}

         lint
         {:doc  "Lint code with clj-kondo"
          :task (if (seq *command-line-args*)
                  (apply shell "clj-kondo" "--lint" *command-line-args*)
                  (apply shell "clj-kondo --lint" paths))}

         guardrails:check-signatures
         {:doc  "Fail when Guardrails signatures are all-generic (map?/any? only)"
          :task (let [pattern "\\[(map\\?|any\\?)(\\s+(map\\?|any\\?))*\\s+=>\\s+(map\\?|any\\?)\\]"
                      result  (shell {:continue true :out :string :err :string}
                                     "rg" "-n" pattern "src/llx/ai/impl")]
                  (case (:exit result)
                    1 (println "Guardrails signature quality gate passed: no all-generic signatures found.")
                    0 (do
                        (println "Guardrails signature quality gate failed: found disallowed signatures:")
                        (print (:out result))
                        (throw (ex-info "Disallowed all-generic Guardrails signatures found."
                                        {:pattern pattern})))
                    (do
                      (when (seq (:err result))
                        (print (:err result)))
                      (throw (ex-info "Failed to run Guardrails signature quality gate."
                                      {:exit (:exit result)})))))}

         qa
         {:doc     "Run full quality assurance: format, lint, and test"
          :depends [fmt lint guardrails:check-signatures test]}

         qa-long
         {:doc     "Run full quality assurance: format, lint, and test"
          :depends [fmt lint guardrails:check-signatures test test:jvm-live]}

         ci
         {:doc     "Run CI checks: test, format check, and lint"
          :depends [test fmt:check lint]}

         jar
         {:override-builtin true
          :depends          [clean]
          :doc              "Build an jar"
          :task             (shell "clojure -T:build jar")}

         clean
         {:override-builtin true
          :doc              "Clean build artifacts"
          :task             (shell "clojure -T:build clean")}

         publish
         {:doc     "Publish the clojure sdk libs to clojars"
          :depends [jar]
          :task    (clojure "-T:build deploy")}}}
