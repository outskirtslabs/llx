{:paths   ["src" "resources"]
 :deps    {metosin/malli              {:mvn/version "0.20.1"}
           com.taoensso/trove         {:mvn/version "1.1.0"}
           funcool/promesa            {:mvn/version "12.0.0-RC2"}
           com.fulcrologic/guardrails {:mvn/version "1.2.16"}
           org.babashka/http-client   {:mvn/version "0.4.23"}
           org.babashka/json          {:mvn/version "0.1.6"}}
 :aliases {:kaocha
           {:extra-paths ["test"]
            :extra-deps  {}
            :main-opts   ["-m" "kaocha.runner"]}

           :funnel
           {:extra-deps {lambdaisland/funnel {:mvn/version "1.6.93"}}
            :main-opts  ["-m" "lambdaisland.funnel"]}

           :dev
           {:extra-paths ["dev" "test"]
            :jvm-opts    ["-Dguardrails.enabled=true"]

            :extra-deps  {dev.weavejester/hashp                    {:mvn/version "0.5.1"}
                          org.slf4j/slf4j-nop                      {:mvn/version "2.0.17"}
                          io.github.tonsky/clj-reload              {:mvn/version "1.0.0"}
                          com.cnuernber/charred                    {:mvn/version "1.038"}
                          djblue/portal                            {:mvn/version "0.63.0"}
                          criterium/criterium                      {:mvn/version "0.4.6"}
                          thheller/shadow-cljs                     {:mvn/version "3.3.6"}
                          com.clojure-goes-fast/clj-async-profiler {:mvn/version "1.7.0"}
                          lambdaisland/kaocha                      {:mvn/version "1.91.1392"}
                          lambdaisland/kaocha-cljs2                {:mvn/version "0.2.72"}
                          kaocha-retry/kaocha-retry                {:mvn/version "0.4.0"}}}

           :shadow-cljs
           {:main-opts ["-m" "shadow.cljs.devtools.cli"]
            :jvm-opts  ["-XX:+UnlockExperimentalVMOptions"
                        "-XX:CompileCommand=blackhole,criterium.blackhole.Blackhole::consume"]}

           :build
           {:deps       {io.github.clojure/tools.build {:git/tag "v0.10.12"
                                                        :git/sha "97c5562"}
                         slipset/deps-deploy           {:mvn/version "0.2.2"}}
            :ns-default build}
           :neil
           {:project {:name        com.outskirtslabs/llx
                      :url         "https://github.com/outskirtslabs/llx"
                      :license     {:id "EUPL-1.2"}
                      :description "Unified LLM client for supported providers with cross-provider context handoff for CLJ, CLJS, and CLJD"
                      :version     "0.0.1"}}}}
